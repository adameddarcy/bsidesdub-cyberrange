@startuml C4_Container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

title Container Diagram - Cyber Range Architecture

Person(participant, "Workshop Participant", "Security analyst")

System_Boundary(dmz, "DMZ Network (10.10.1.0/24)") {
    Container(proxy, "Nginx Reverse Proxy", "nginx:1.25-alpine", "Entry point from internet. Routes HTTP to Juice Shop.\n[VULN] Server version exposed, no rate limiting")
    Container(juiceshop_dmz, "OWASP Juice Shop", "bkimminich/juice-shop", "Deliberately vulnerable web app. Primary threat modelling target.\n[VULN] SQLi, XSS, IDOR, weak JWT")
    Container(bastion_dmz, "Bastion Host", "openssh-server", "Jump host for participants.\n[VULN] Password auth enabled, broad network access")
}

System_Boundary(app, "Application Network (10.10.2.0/24)") {
    Container(api, "Internal API", "httpbin", "Mock internal microservice.\n[VULN] No auth, reachable via SSRF")
    Container(agent, "Agent Service", "Python Flask", "Mock LLM-backed agentic service with tool access.\n[VULN] No approval gate, prompt injection, no auth")
    Container(db_app, "MySQL Database", "mysql:8.0", "Backend datastore.\n[VULN] Root password 'password', query logging enabled")
}

System_Boundary(internal, "Internal Network (10.10.3.0/24) [No External Routing]") {
    Container(ldap, "OpenLDAP", "osixia/openldap", "Mock corporate directory.\n[VULN] Anonymous bind enabled, weak admin password")
}

System_Boundary(monitoring, "Monitoring Network (10.10.4.0/24)") {
    Container(loki, "Loki", "grafana/loki", "Log aggregation backend")
    Container(promtail, "Promtail", "grafana/promtail", "Log shipper - collects container logs")
    Container(grafana, "Grafana", "grafana/grafana", "Dashboard for observing attack artefacts.\n[INFO] Anonymous access for workshop convenience")
}

Rel(participant, proxy, "Browses target app", "HTTP :80")
Rel(participant, bastion_dmz, "SSH into range", "SSH :2222")
Rel(participant, grafana, "Views logs", "HTTP :3000")

Rel(proxy, juiceshop_dmz, "Proxies requests", "HTTP :3000")
Rel(juiceshop_dmz, api, "Can reach via SSRF", "HTTP")
Rel(juiceshop_dmz, db_app, "Queries", "MySQL :3306")
Rel(agent, api, "Executes tool calls", "HTTP")
Rel(agent, db_app, "Can access", "MySQL :3306")
Rel(agent, ldap, "Can query", "LDAP :389")
Rel(db_app, ldap, "Internal network peer", "")

Rel(bastion_dmz, juiceshop_dmz, "Can reach", "All ports")
Rel(bastion_dmz, api, "Can reach", "All ports")
Rel(bastion_dmz, agent, "Can reach", "All ports")
Rel(bastion_dmz, db_app, "Can reach", "All ports")
Rel(bastion_dmz, ldap, "Can reach", "All ports")

Rel(promtail, loki, "Ships logs", "HTTP :3100")
Rel(grafana, loki, "Queries logs", "HTTP :3100")

@enduml
