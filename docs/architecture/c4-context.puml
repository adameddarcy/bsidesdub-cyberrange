@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context Diagram - Cyber Range Threat Modelling Workshop

Person(participant, "Workshop Participant", "Security analyst learning threat modelling via hands-on exercises")
Person(admin, "Range Administrator", "Sets up and manages the cyber range infrastructure")

System(cyberRange, "Cyber Range", "Three-tier deliberately vulnerable web application environment for STRIDE threat modelling workshops")

System_Ext(internet, "Simulated Internet", "External network from participant perspective")
System_Ext(vps, "VPS Host", "DigitalOcean droplet running Docker")

Rel(participant, internet, "Accesses via", "HTTP/HTTPS, SSH")
Rel(internet, cyberRange, "Routes to", "Port 80, 443, 2222, 3000")
Rel(admin, vps, "Manages via", "SSH port 22")
Rel(vps, cyberRange, "Hosts", "Docker Compose")
Rel(participant, cyberRange, "Analyses threats in")

@enduml
